# ============================================================
#  智能反馈聚合系统 — 环境配置示例
#  复制此文件为 .env 并填入真实值后启动服务
#  修改后需重启服务方可生效
# ============================================================

# ---- HTTP 服务 ----
PORT=4000
# 说明: 后端服务监听端口，可任意修改为未被占用的端口

# ---- JWT 认证 ----
JWT_SECRET=change-me-to-a-random-string
# ⚠️ 生产环境务必更换：openssl rand -hex 64
# 说明: JWT 令牌签名密钥，泄露后任何人可伪造登录身份

# ---- CORS 跨域 ----
# CORS_ORIGIN=http://localhost:5173
# 备选: https://your-production-domain.com
# 说明: 允许跨域请求的前端域名。不设置则默认使用 FRONTEND_REDIRECT_URI

# ============================================================
# AI 对话模型 — 用于生成 issue 摘要标题和描述
# ============================================================
AI_CHAT_BASE_URL=https://api.deepseek.com/v1
# 备选: 任何兼容 OpenAI 格式的自有代理地址
# 说明: Chat 补全 API 端点，兼容 OpenAI SDK 格式即可

AI_CHAT_API_KEY=sk-your-chat-api-key
# ⚠️ 你的 API 密钥，按所选服务商填写

AI_CHAT_MODEL=deepseek-v4-flash
# 说明: 摘要生成模型名，需与 BASE_URL 对应服务商一致

AI_CHAT_REASONING_ENABLED=false
# 说明: 开启后模型逐步推理，摘要质量可能提升但消耗更多 token

AI_CHAT_REASONING_EFFORT=high
# 说明: 推理强度，仅在 REASONING_ENABLED=true 时生效

AI_CHAT_REASONING_STYLE=deepseek
# 备选:  deepseek (DeepSeek 格式 reasoning_style)
#        openai  (OpenAI 格式 reasoning_effort)
#        none    (不附加推理参数)
# 说明: 思维链提交格式。deepseek=thinking 包裹，openai=仅effort

AI_CHAT_RESPONSE_FORMAT_STYLE=json
# 说明: json 强制 JSON 输出（prompt 需含 "json" 字样），none 不约束

# ============================================================
# AI 图片描述模型 — 用于将用户上传截图转为文本描述【目前还有问题别开】
# ============================================================
#AI_IMAGE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 备选: https://api.openai.com/v1
# 说明: 图片描述 API 端点，需支持多模态/视觉理解

#AI_IMAGE_API_KEY=sk-your-image-api-key
# ⚠️ 图片描述服务的 API 密钥

#AI_IMAGE_MODEL=qwen3.7-plus
# 说明: 图片描述模型名，需支持图片输入

AI_IMAGE_REASONING_ENABLED=false
# 备选: true

AI_IMAGE_REASONING_EFFORT=high
# 备选: low / medium / max

AI_IMAGE_REASONING_STYLE=none
# 备选: deepseek / openai

AI_IMAGE_RESPONSE_FORMAT_STYLE=none
# 备选: json

# ============================================================
# AI 向量嵌入模型 — 用于将反馈文本转为向量，做语义聚类匹配
# ============================================================
AI_EMBEDDING_BASE_URL=https://api.deepseek.com/v1
# 说明: 嵌入向量 API 端点

AI_EMBEDDING_API_KEY=sk-your-embedding-api-key
# ⚠️ 嵌入服务的 API 密钥

AI_EMBEDDING_MODEL=deepseek-v4-flash
# 说明: 文本向量化模型名。系统统一使用 128 维，选择兼容模型即可

AI_EMBEDDING_IS_EMBEDDING=false
# 备选: true
# 说明: true=独立 /embeddings 端点（OpenAI 标准方式）
#       false=走 /chat/completions 让模型输出 JSON 向量

AI_EMBEDDING_REASONING_ENABLED=false
# 备选: true/false（通常false，嵌入不需要推理）

AI_EMBEDDING_REASONING_EFFORT=high
# 说明：推理思维链强度

AI_EMBEDDING_REASONING_STYLE=deepseek
# 备选: deepseek / openai / none

AI_EMBEDDING_RESPONSE_FORMAT_STYLE=json
# 备选: json / none

# ---- 聚类阈值 ----
AI_CLUSTER_SIMILARITY_THRESHOLD=0.85
# 说明: 语义相似度阈值。越高越倾向新建 issue，越低越倾向归并（0.00-1.00）

# ---- 数据存储 ----
DATABASE_FILE=./data/report-site.db
# 说明: SQLite 数据库文件路径，支持相对或绝对路径

IMAGE_STORAGE_PATH=./uploads
# 备选: ./data/images
#        /data/storage/images
# 说明: 用户上传图片的存储目录

# ============================================================
# VDS 开放平台 OAuth 配置 — 在 https://developer.vds.pub 注册
# ============================================================
VDP_BASE_URL=https://open-global.vdsentnet.com
# 说明: VDS API 网关地址，按所在地选择

OAUTH_CLIENT_ID=vap_your_app_id
# ⚠️ 应用 ID（vap_ 开头），VDS 开发者平台创建应用获取

OAUTH_CLIENT_SECRET=your-client-secret
# ⚠️ 应用密钥，VDS 开发者平台获取

OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/sso/callback
# 备选: https://your-domain.com/api/auth/sso/callback
# 说明: OAuth 回调地址，需与 VDS 平台配置完全一致

FRONTEND_REDIRECT_URI=http://localhost:5173
# 备选: https://your-frontend-domain.com
# 说明: 登录成功后的前端跳转地址

# ---- 管理员配置 ----
# 使用 VDS SSO 登录后，username 匹配此值的用户自动获得 admin 角色
ADMIN_USERNAME=your-admin-username
# 说明: 填入 VDS 用户的 username。该用户登录后拥有后台管理权限
