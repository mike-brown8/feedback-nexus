# ============================================================
#  智能反馈聚合系统 — 环境配置示例（火山方舟版）
#  复制此文件为 .env 并填入真实值后启动服务
#  修改后需重启服务方可生效
# ============================================================

# ---- HTTP 服务 ----
PORT=4000
# 后端服务监听端口，可任意修改为未被占用的端口

# ---- JWT 认证 ----
JWT_SECRET=change-me-to-a-random-string
# ⚠️ 生产环境务必更换：openssl rand -hex 64
# JWT 令牌签名密钥，泄露后任何人可伪造登录身份

# ---- CORS 跨域 ----
# CORS_ORIGIN=http://localhost:5173
# 允许跨域请求的前端域名。不设置则默认使用 FRONTEND_REDIRECT_URI

# ============================================================
# 火山方舟 — 全局 API 配置
# ============================================================
ARK_API_KEY=your-ark-api-key-here
# ⚠️ 火山方舟 API Key，可在火山引擎控制台获取
# 各模块可单独覆盖（AI_NAMING_API_KEY / AI_IMAGE_API_KEY / AI_EMBEDDING_API_KEY）

# ============================================================
# AI — 命名/摘要模型
#   用于生成 issue 标题和描述。唯一允许开启思维链的模块。
#   命名策略：第一个反馈起名，之后每五个反馈重新起名。
#   模型输出 JSON 格式（提示词驱动）：{"title":"xxx","desc":"xxxx"}
# ============================================================
AI_NAMING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 火山方舟 Chat API 端点，通常无需修改

AI_NAMING_MODEL=doubao-seed-2-1-pro-260628
# 模型 Endpoint ID，在火山方舟控制台「模型推理-在线推理」中创建端点后获取

# ---- 思维链配置（仅命名模块可用） ----
AI_NAMING_REASONING_ENABLED=true
# true=开启思维链（在线推理/常规）；false=关闭

AI_NAMING_REASONING_EFFORT=medium
# 推理强度，仅在 REASONING_ENABLED=true 时生效
# 可选值：minimal / low / medium / high

AI_NAMING_MAX_COMPLETION_TOKENS=4096
# 最大补全 token 数（火山方舟 max_completion_tokens）
# 思维链开启时思考过程也会消耗此配额

# ============================================================
# AI — 图片描述模型
#   用于将用户上传的截图转为文本描述，追加到反馈原文末尾。
#   注意：强制关闭思维链。
# ============================================================
AI_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 火山方舟 Chat API 端点

AI_IMAGE_MODEL=doubao-seed-2-1-pro-260628
# 需选择支持视觉理解（多模态）的模型

AI_IMAGE_MAX_COMPLETION_TOKENS=2048
# 最大补全 token 数（火山方舟 max_completion_tokens）

# ============================================================
# AI — 向量嵌入模型
#   用于将反馈文本转为向量，做语义聚类匹配。
#   注意：强制关闭思维链，仅使用独立 /embeddings 端点。
# ============================================================
AI_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 火山方舟 /embeddings 端点

AI_EMBEDDING_MODEL=doubao-embedding-vision-250615
# 火山方舟文本向量化模型

# ============================================================
# 聚类阈值
# ============================================================
AI_CLUSTER_SIMILARITY_THRESHOLD=0.85
# 语义相似度阈值，范围 0.00~1.00
# 越高越倾向新建 issue，越低越倾向归入已有 issue

# ---- 数据存储 ----
DATABASE_FILE=./data/report-site.db
# SQLite 数据库文件路径，支持相对或绝对路径

MAX_DAILY_FEEDBACKS=3
# 每用户每日最多上传图片数

IMAGE_STORAGE_PATH=./uploads
# 用户上传图片的存储目录

# ============================================================
# VDS 开放平台 OAuth 配置
# 在 https://developer.vds.pub 注册应用获取
# ============================================================
VDP_BASE_URL=https://open-global.vdsentnet.com
# VDS API 网关地址，按所在地选择

OAUTH_CLIENT_ID=vap_your_app_id
# ⚠️ 应用 ID（vap_ 开头），VDS 开发者平台创建应用获取

OAUTH_CLIENT_SECRET=your-client-secret
# ⚠️ 应用密钥，VDS 开发者平台获取

OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/sso/callback
# OAuth 回调地址，需与 VDS 平台配置完全一致
# 生产环境改为 https://your-domain.com/api/auth/sso/callback

FRONTEND_REDIRECT_URI=http://localhost:5173
# 登录成功后的前端跳转地址
# 生产环境改为 https://your-frontend-domain.com

# ---- 管理员配置 ----
ADMIN_USERNAME=your-admin-username
# 使用 VDS SSO 登录后，username 匹配此值的用户自动获得 admin 角色
